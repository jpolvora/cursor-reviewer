{
  "name": "cursor-reviewer",
  "version": "0.2.12",
  "description": "Code reviewer agêntico portável (review-only) para pipeline Azure DevOps usando @cursor/sdk",
  "license": "MIT",
  "author": "Jone Polvora",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpolvora/cursor-reviewer.git"
  },
  "bugs": {
    "url": "https://github.com/jpolvora/cursor-reviewer/issues"
  },
  "homepage": "https://github.com/jpolvora/cursor-reviewer#readme",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:release": "bash scripts/build-release.sh",
    "start": "node dist/index.js",
    "review": "tsx --env-file-if-exists=.env src/index.ts",
    "review:local": "tsx --env-file-if-exists=.env src/index.ts --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && tsx --test test/**/*.test.ts",
    "test:seed": "tsx src/seed/run-seed-test.ts",
    "seed:install": "tsx src/seed/install-fixtures.ts",
    "seed:uninstall": "tsx src/seed/uninstall-fixtures.ts",
    "seed:verify-clean": "tsx src/seed/verify-clean.ts"
  },
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@connectrpc/connect": "^2.1.2",
    "@connectrpc/connect-node": "^2.1.2",
    "@cursor/sdk": "^1.0.19",
    "@opencode-ai/sdk": "^1.17.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
