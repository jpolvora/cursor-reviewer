# Obrigatório — API key do Cursor (Dashboard → Integrations ou Service Account)
CURSOR_API_KEY=cursor_...

# Azure DevOps — pipeline usa SYSTEM_ACCESSTOKEN automaticamente
# Para teste local com publicação/gate, use um PAT com Code (Read & Write) + Work Items (Read)
AZURE_DEVOPS_EXT_PAT=

# Modelo do agente — ID canônico Composer 2.5 no SDK (default)
CURSOR_REVIEWER_MODEL=composer-2.5

# Tag que identifica comentários do bot na PR (deve bater com a pipeline)
CURSOR_REVIEWER_BOT_TAG=[Cursor Reviewer]

# Modo verboso (default: true)
CURSOR_REVIEWER_VERBOSE=true

# Timeout do agente em milissegundos (default: 600000 = 10 min)
# Ao estourar, o run é cancelado via run.cancel() (não apenas interrompe o stream).
# CURSOR_REVIEWER_TIMEOUT_MS=600000

# Sandbox read-only do SDK (default: true) — restringe escritas ao cwd e nega rede.
# Reforço técnico do modo review-only; defina false apenas para depuração local.
# Em ambientes sem suporte a sandbox (ex.: agentes de CI) o runner cai
# automaticamente para execução sem sandbox (read-only segue via SYSTEM_PROMPT).
# CURSOR_REVIEWER_SANDBOX=true

# Dry-run local (default: false) — sem publicar threads; exit 0 salvo erro
CURSOR_REVIEWER_DRY_RUN=false

# Incluir staged/unstaged/untracked vs HEAD além do diff de branch (default: false)
# Ativado automaticamente com --seed-test ou CURSOR_REVIEWER_SEED_TEST=true
# CURSOR_REVIEWER_INCLUDE_UNCOMMITTED=false

# Modo validação seed — prompt e diff para fixtures temporárias (default: false)
# CURSOR_REVIEWER_SEED_TEST=false

# Branch de comparação do diff (default: refs/heads/master)
# A branch source é sempre a branch da PR (pipeline) ou a branch git atual (local)
CURSOR_REVIEWER_TARGET_BRANCH=refs/heads/master

# Self-review: por padrão scripts/cursor-reviewer/** é excluído do diff (evita loops).
# Defina true apenas ao desenvolver/testar o próprio runner.
# CURSOR_REVIEWER_REVIEW_SELF=false

# Padrões glob extras de exclusão (separados por vírgula), além dos defaults.
# CURSOR_REVIEWER_EXTRA_EXCLUDE_PATTERNS=scripts/outro-tool/**
