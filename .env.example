# =============================================================================
# Cursor Reviewer — variáveis de ambiente
# Copie para .env e ajuste: cp .env.example .env
# Documentação completa: README.md
# =============================================================================

# -----------------------------------------------------------------------------
# Autenticação (obrigatório no bootstrap)
# -----------------------------------------------------------------------------

# Chave do Cursor (Dashboard → Integrations ou Service Account)
# Obrigatória mesmo com engine opencode (validação no loadConfig)
CURSOR_API_KEY=cursor_...

# Azure DevOps — pipeline usa SYSTEM_ACCESSTOKEN automaticamente
# Local: PAT com Code (Read & Write) + Work Items (Read)
AZURE_DEVOPS_EXT_PAT=

# GitHub — REST/GraphQL (alias: GH_TOKEN)
GITHUB_TOKEN=ghp_...

# -----------------------------------------------------------------------------
# Engine e modelo LLM
# -----------------------------------------------------------------------------

# Engine de execução: cursor-sdk (default) | opencode
CURSOR_REVIEWER_ENGINE=cursor-sdk

# Modelo — depende da engine:
#   cursor-sdk: ID do Cursor (composer-2.5, claude-sonnet-4-6, gpt-5.4, ...)
#   opencode:     provider/model (opencode-go/deepseek-v4-flash, anthropic/claude-sonnet-4-6, ...)
CURSOR_REVIEWER_MODEL=composer-2.5

# --- Exemplo: OpenCode Go + DeepSeek V4 Flash (servidor local) ---
# CURSOR_REVIEWER_ENGINE=opencode
# CURSOR_REVIEWER_MODEL=opencode-go/deepseek-v4-flash
# CURSOR_REVIEWER_OPENCODE_URL=http://127.0.0.1:43147

# --- Exemplo: OpenCode Zen ---
# CURSOR_REVIEWER_ENGINE=opencode
# CURSOR_REVIEWER_MODEL=opencode/deepseek-v4-flash

# -----------------------------------------------------------------------------
# OpenCode (apenas quando CURSOR_REVIEWER_ENGINE=opencode)
# Credenciais LLM ficam no servidor: ~/.local/share/opencode/auth.json
# GitHub Actions: use secret OPENCODE_GO_API_KEY (job review-opencode)
# OPENCODE_GO_API_KEY=sk-...
# -----------------------------------------------------------------------------

# URL de servidor já em execução (opencode serve / opencode --port N)
# Alias aceito: OPENCODE_SERVER_URL
CURSOR_REVIEWER_OPENCODE_URL=http://127.0.0.1:43147
# OPENCODE_SERVER_URL=http://127.0.0.1:43147

# Servidor embutido (quando URL acima está vazia — runner sobe opencode serve)
CURSOR_REVIEWER_OPENCODE_HOSTNAME=127.0.0.1
CURSOR_REVIEWER_OPENCODE_PORT=4096

# Agente OpenCode na sessão (default: explore = read-only)
CURSOR_REVIEWER_OPENCODE_AGENT=explore

# -----------------------------------------------------------------------------
# Contexto da PR / plataforma (local ou override de CI)
# -----------------------------------------------------------------------------

# ID da PR (local); em CI: SYSTEM_PULLREQUEST_PULLREQUESTID ou GITHUB_REF
# CURSOR_REVIEWER_PR_ID=42

# Azure DevOps — overrides quando não há variáveis de pipeline
# CURSOR_REVIEWER_ADO_ORG=minha-org
# CURSOR_REVIEWER_ADO_PROJECT=meu-projeto
# CURSOR_REVIEWER_ADO_REPO=meu-repo

# Raiz do repositório alvo (default: detectado via scripts/cursor-reviewer)
# CURSOR_REVIEWER_REPO_ROOT=/caminho/para/repo-alvo

# Branch de comparação do diff (source = branch da PR ou git atual)
CURSOR_REVIEWER_TARGET_BRANCH=refs/heads/master

# -----------------------------------------------------------------------------
# Comportamento do review
# -----------------------------------------------------------------------------

# Tag do bot nos comentários (deve bater com a pipeline)
CURSOR_REVIEWER_BOT_TAG=[Cursor Reviewer]

# Logs detalhados (default: true)
CURSOR_REVIEWER_VERBOSE=true

# Timeout da sessão em ms (default: 600000 = 10 min) — ambas engines
# cursor-sdk: cancela via run.cancel(); opencode: abort na sessão
CURSOR_REVIEWER_TIMEOUT_MS=600000

# Sandbox read-only do cursor-sdk (default: true)
# false apenas para debug local; CI sem sandbox cai automaticamente sem sandbox
CURSOR_REVIEWER_SANDBOX=true

# Dry-run — não publica threads (default: false)
CURSOR_REVIEWER_DRY_RUN=false

# Incluir staged/unstaged/untracked vs HEAD (default: false)
# Ativado automaticamente com --seed-test
# CURSOR_REVIEWER_INCLUDE_UNCOMMITTED=false

# Modo validação seed (fixtures E2E)
# CURSOR_REVIEWER_SEED_TEST=false

# Rodadas antes de escalar para revisão humana (default: 5; 0 desativa)
# CURSOR_REVIEWER_MAX_ROUNDS=5

# Incluir o próprio runner no diff (default: false; só para dev)
# CURSOR_REVIEWER_REVIEW_SELF=false

# Globs extras de exclusão (CSV), além dos defaults
# CURSOR_REVIEWER_EXTRA_EXCLUDE_PATTERNS=scripts/outro-tool/**,**/generated/**

# -----------------------------------------------------------------------------
# Stack tecnológica e diff
# -----------------------------------------------------------------------------

# Stack: ABP/Angular | PHP/Laravel | Next.js/React | TypeScript | Custom
# Omitida: autodetecção na raiz do repo; fallback ABP/Angular
# CURSOR_REVIEWER_STACK=TypeScript

# Obrigatório com stack Custom — arquivo ou string inline
# CURSOR_REVIEWER_CUSTOM_PROMPT=./docs/meu-prompt-review.md

# Globs de inclusão no diff (CSV); sobrescreve padrão da stack
# CURSOR_REVIEWER_INCLUDE_PATTERNS=**/*.py,**/*.go

# -----------------------------------------------------------------------------
# Logging / terminal (opcional)
# -----------------------------------------------------------------------------

# Cores no prompt (Azure Pipelines e TTY); default: ligado
# CURSOR_REVIEWER_PROMPT_COLOR=false

# NO_COLOR=1
# FORCE_COLOR=1
